{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "usestockai-mcp",
      "version": "0.1.0",
      "title": "UseStockAI Signals"
    },
    "tools": [
      {
        "name": "list_live_signals",
        "title": "List live trading signals",
        "description": "Return the current live AI-generated stock/crypto trading signals (BUY/SELL) with confidence, entry price, regime, strategy, and reasoning. Signals expire after 24h.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25,
              "description": "Max signals to return."
            },
            "signal_type": {
              "type": "string",
              "enum": [
                "BUY",
                "SELL"
              ],
              "description": "Filter by direction."
            },
            "min_confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Minimum confidence score (0-100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_signal",
        "title": "Get live signal for ticker",
        "description": "Return the current live trading signal for a specific ticker symbol, if one is active.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "ticker": {
              "type": "string",
              "minLength": 1,
              "maxLength": 15,
              "description": "Ticker symbol, e.g. AAPL or BTC-USD."
            }
          },
          "required": [
            "ticker"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_stock_price",
        "title": "Get current stock price",
        "description": "Fetch the latest price and daily change for a stock or crypto ticker via the app's server-side Yahoo Finance proxy.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "ticker": {
              "type": "string",
              "minLength": 1,
              "maxLength": 15,
              "description": "Ticker symbol, e.g. AAPL, TSLA, BTC-USD."
            }
          },
          "required": [
            "ticker"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
